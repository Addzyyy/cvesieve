{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "grype",
          "version": "0.74.0",
          "rules": [
            {
              "id": "CVE-2024-4444",
              "shortDescription": { "text": "libssl remote code execution" },
              "helpUri": "https://nvd.nist.gov/vuln/detail/CVE-2024-4444",
              "properties": {
                "cvssV3_severity": "CRITICAL",
                "cvssV3_vectorString": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H",
                "fix-versions": ["3.0.15"]
              }
            },
            {
              "id": "CVE-2024-5555",
              "shortDescription": { "text": "bash local information disclosure" },
              "helpUri": "https://nvd.nist.gov/vuln/detail/CVE-2024-5555",
              "properties": {
                "cvssV3_severity": "LOW",
                "cvssV3_vectorString": "CVSS:3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:L/I:N/A:N"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CVE-2024-4444",
          "level": "error",
          "message": { "text": "libssl3 3.0.11 is vulnerable" },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "libssl3",
                  "kind": "module",
                  "fullyQualifiedName": "libssl3@3.0.11"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CVE-2024-5555",
          "level": "note",
          "message": { "text": "bash 5.2.15 is vulnerable" },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "bash",
                  "kind": "module",
                  "fullyQualifiedName": "bash@5.2.15"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
