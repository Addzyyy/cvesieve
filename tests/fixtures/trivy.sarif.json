              ]
            }
          ]
        },
        {
          "ruleId": "CVE-2024-3333",
          "level": "warning",
          "message": { "text": "zlib 1.2.11: CVE-2024-3333" },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "zlib",
                  "kind": "module",
                  "fullyQualifiedName": "zlib@1.2.11"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
